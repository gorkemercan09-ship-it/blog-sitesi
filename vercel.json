{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.2" },
    "*.php": { "runtime": "vercel-php@0.7.2" },
    "admin/**/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/admin", "dest": "/admin/index.php" },
    { "src": "/(assets|uploads)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
